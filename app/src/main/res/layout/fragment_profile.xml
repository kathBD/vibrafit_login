<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- Deja espacio para el botón inferior si lo agregas luego -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- HEADER CON IMAGEN -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/image195" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Perfil"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="16dp"/>
            </RelativeLayout>

            <!-- CONTENIDO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1B1E28"
                android:padding="24dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Imagen usuario -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/logo34210"
                    android:layout_marginBottom="20dp" />

                <!-- Nombre -->
                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Rol -->
                <TextView
                    android:id="@+id/tvRol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2465E1"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Email estilo input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/rounded_edittext"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="📧"
                        android:textColor="#888888"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/tvCorreo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="12dp"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- Botón Editar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditarPerfil"
                    android:layout_width="200dp"
                    android:layout_height="48dp"
                    android:text="Editar Perfil"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="#2465E1"
                    android:layout_marginBottom="16dp"/>

                <!-- Botón Cerrar Sesión -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCerrarSesion"
                    android:layout_width="200dp"
                    android:layout_height="48dp"
                    android:text="Cerrar Sesión"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="#DC3545"/>

                <!-- Botón Gestión de Usuarios (solo ADMIN) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGestionUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Gestión de Usuarios"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="#2465E1"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/tu_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>